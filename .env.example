# Copy to .env and set values. Do not commit .env.
# ENVIRONMENT=local  → SQLite (no DB server). Use for local dev when Neon is unreachable.
# ENVIRONMENT=dev    → uses DEV_DATABASE_URL (Neon dev)
# ENVIRONMENT=prod   → uses PROD_DATABASE_URL (Neon prod)
# DATABASE_URL=...   → override (e.g. postgres://localhost:5432/bloomhub_local)
# SECRET_KEY=your-secret-key
# DEBUG=true
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare R2 (optional — file uploads use R2 when all four are set)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=bloomhub
# R2_VERIFY_SSL=false  # only for local if you get SSL handshake errors (Python 3.14 + R2)
