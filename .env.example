# Copy to .env and set values. Do not commit .env.
# ENVIRONMENT=local  → SQLite (no DB server). Use for local dev when Neon is unreachable.
# ENVIRONMENT=dev    → uses DEV_DATABASE_URL (Neon dev)
# ENVIRONMENT=prod   → uses PROD_DATABASE_URL (Neon prod)
# DATABASE_URL=...   → override (e.g. postgres://localhost:5432/bloomhub_local)
# SECRET_KEY=your-secret-key
# DEBUG=true
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare R2 (optional — file uploads use R2 when all four are set)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=bloomhub
# R2_VERIFY_SSL=false  # only for local if you get SSL handshake errors (Python 3.14 + R2)

# Jira OAuth 2.0 (3LO) — per-user Atlassian connections.
# Register an OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/.
# Required scopes: read:jira-work read:jira-user read:me offline_access.
# JIRA_OAUTH_CLIENT_ID=...
# JIRA_OAUTH_CLIENT_SECRET=...
# JIRA_OAUTH_REDIRECT_URI=https://your-frontend-host/oauth/jira/callback
# JIRA_TOKEN_ENCRYPTION_KEY=base64-or-long-random-string  # encrypts per-user access/refresh tokens at rest

# Tempo OAuth 2.0 — per-user Tempo Cloud connections.
# Register an OAuth 2.0 application in Tempo Cloud: Tempo → Settings → API integration → OAuth 2.0 Applications.
# Required Tempo app access: Worklogs view, plus any extra namespaces you import.
# TEMPO_OAUTH_CLIENT_ID=...
# TEMPO_OAUTH_CLIENT_SECRET=...
# TEMPO_OAUTH_REDIRECT_URI=https://your-frontend-host/oauth/tempo/callback
# TEMPO_OAUTH_JIRA_URL=https://your-site.atlassian.net
